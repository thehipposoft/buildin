{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/inversiones/layout,_N_T_/inversiones/page,_N_T_/inversiones"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/inversiones/__PAGE__",
    "/inversiones",
    "/_index",
    "/_head"
  ]
}